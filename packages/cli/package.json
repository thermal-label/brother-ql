{
  "name": "@thermal-label/brother-ql-cli",
  "version": "0.0.1",
  "description": "CLI for Brother QL label printers",
  "keywords": [
    "brother",
    "brother-ql",
    "label-printer",
    "thermal-label",
    "cli"
  ],
  "type": "module",
  "author": "Mannes Brak",
  "license": "MIT",
  "homepage": "https://thermal-label.github.io/brother-ql/",
  "repository": {
    "type": "git",
    "url": "https://github.com/thermal-label/brother-ql.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/thermal-label/brother-ql/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mannes"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mannes"
    }
  ],
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "bin": {
    "brother-ql": "./bin/brother-ql.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mbtech-nl/bitmap": "^0.1.0",
    "@thermal-label/brother-ql-node": "workspace:*",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@mbtech-nl/tsconfig": "^1.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
}
