// Brother DK consumables registry.
//
// Entries are listed in the order they appear in the historical
// `MEDIA` const: continuous rolls first (sorted roughly by width),
// then die-cut labels. The compile script folds this into the
// `MEDIA` keyed-by-id map exposed to runtime callers; the array
// form here is just easier to read and edit.
//
// `id` is the firmware media identifier the printer reports in its
// 32-byte status response. `palette` is set on multi-ink media
// (DK-22251 today) — driver routes those through
// `renderMultiPlaneImage`. Rectangular die-cut entries set
// `defaultOrientation: 'horizontal'` so landscape input auto-rotates
// to read along tape feed direction.

[
  // Continuous length tape
  {
    id: 257,
    tapeSystem: 'dk',
    name: '12mm continuous (DK-22214)',
    type: 'continuous',
    widthMm: 12,
    printAreaDots: 106,
    leftMarginPins: 585,
    rightMarginPins: 29,
