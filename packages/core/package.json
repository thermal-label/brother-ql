{
  "name": "@thermal-label/brother-ql-core",
  "version": "0.6.1",
  "description": "Protocol encoding, device registry, and media registry for Brother QL label printers",
  "keywords": [
    "brother",
    "brother-ql",
    "label-printer",
    "thermal-label",
    "usb",
    "protocol"
  ],
  "type": "module",
  "author": "Mannes Brak",
  "license": "MIT",
  "homepage": "https://thermal-label.github.io/brother-ql/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/thermal-label/brother-ql.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/thermal-label/brother-ql/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mannes"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mannes"
    }
  ],
  "files": [
    "dist",
    "src",
    "data/devices.json",
    "data/media.json",
    "README.md"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "compile-data": "node ../../scripts/compile-data.mjs",
    "build": "pnpm run compile-data && tsc -p tsconfig.json",
    "typecheck": "pnpm run compile-data && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run compile-data && vitest run",
    "test:coverage": "pnpm run compile-data && vitest run --coverage"
  },
  "dependencies": {
    "@mbtech-nl/bitmap": "^1.3.0",
    "@thermal-label/contracts": "^0.6.0"
  },
  "devDependencies": {
    "@mbtech-nl/tsconfig": "^1.1.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "json5": "^2.2.3",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
}
